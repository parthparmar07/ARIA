# Required
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# Session store. Use redis:// for local, or an Upstash URL for serverless.
REDIS_URL=redis://localhost:6379

# CORS — your frontend origin (Lovable preview, localhost, or your domain)
CORS_ORIGIN=http://localhost:5173

# Optional
MODEL=claude-sonnet-4-20250514
MAX_TURNS=6
